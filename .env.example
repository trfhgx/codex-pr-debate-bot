# GitHub webhook verification.
GITHUB_WEBHOOK_SECRET=

# GitHub App auth (optional, for production multi-repo installs).
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_PRIVATE_KEY=

# Holder account: repo admin that invites the replier and manages webhooks.
GITHUB_HOLDER_LOGIN=
GITHUB_HOLDER_TOKEN=
GITHUB_HOLDER_USE_GH_CLI_TOKEN=false
GITHUB_HOLDER_COLLABORATOR_PERMISSION=admin

# Replier account: identity that posts PR comments.
GITHUB_REPLIER_LOGIN=
GITHUB_REPLIER_TOKEN=
GITHUB_REPLIER_USE_GH_CLI_TOKEN=true

# Re-sync enabled repo webhooks when the tunnel URL changes after restart.
GITHUB_AUTO_SYNC_WEBHOOKS=true

# Marker that activates a watched repo PR. Empty string means handle every PR comment.
GITHUB_TRIGGER_PHRASE=codex
# 0 disables automatic polling. Dashboard "Poll now" still works.
GITHUB_POLL_INTERVAL_SECONDS=0

# Debate prompt/comment style.
COMMENT_STYLE_PATH=docs/comment-style.md

# State.
DATABASE_PATH=./bot.sqlite3
TUNNEL_INFO_PATH=./tunnel-info.json

# Dev tunnel runner. TUNNEL_PROVIDER can be auto, cloudflared, ngrok, localtunnel, or none.
TUNNEL_PROVIDER=auto
SERVER_HOST=127.0.0.1
SERVER_PORT=8088

# Codex app-server websocket. Start it with:
# /Applications/Codex.app/Contents/Resources/codex app-server --listen ws://127.0.0.1:8765
CODEX_THREAD_WS_URL=ws://127.0.0.1:8765
CODEX_THREAD_CWD=/tmp
CODEX_THREAD_MODEL=
CODEX_THREAD_EFFORT=medium
CODEX_THREAD_TIMEOUT_SECONDS=600